{
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": [ "dom", "dom.iterable", "esnext" ],
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "es6",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "strict": true,
    "baseUrl": "./src",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@components/*": ["components/*"],
      "@layouts/*": ["layouts/*"],
      "@services/*": ["services/*"]
    }
  },
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ]
}