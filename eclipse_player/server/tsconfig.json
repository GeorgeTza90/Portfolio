{
  "compilerOptions": {    
    "target": "ES2020",
    "module": "node16",
    "rootDir": "./src",
    "outDir": "./dist",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,        
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["src"]
}