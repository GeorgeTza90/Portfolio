<UserControl
    x:Class="Eclipse_Player_Desktop.Components.Nav"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Eclipse_Player_Desktop.Components"
    Height="60"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Top">

    <Border>
        <Border.Background>
            <LinearGradientBrush StartPoint="1,0" EndPoint="1,1">
                <GradientStop Color="#B3252525" Offset="0"/>
                <GradientStop Color="#B7111112" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="250">
            <Button x:Name="HomeButton" Style="{StaticResource NavbarButtonStyle}">
                <Image Source="/Assets/icons/home.png" Width="40" Height="40" Opacity="0.5"/>
            </Button>
            <Button x:Name="PlayerButton" Style="{StaticResource NavbarButtonStyle}">
                <Image Source="/Assets/icons/player.png" Width="40" Height="40" Opacity="0.5"/>
            </Button>
            <Button x:Name="LibraryButton" Style="{StaticResource NavbarButtonStyle}">
                <Image Source="/Assets/icons/library.png" Width="40" Height="40" Opacity="0.5"/>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
